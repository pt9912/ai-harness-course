<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">
<!-- AGENTS.md §J-1 Suppression-Verbot:
     SuppressWarningsHolder fängt @SuppressWarnings ab und kann via
     SuppressWarningsFilter konfiguriert werden; wir lassen den Filter
     bewusst weg, sodass @SuppressWarnings nicht für Checkstyle-Stilfehler
     aktiviert werden kann. -->
<module name="Checker">
    <module name="TreeWalker">
        <module name="SuppressWarningsHolder"/>
        <module name="MissingJavadocType">
            <property name="scope" value="public"/>
        </module>
        <module name="AvoidStarImport"/>
        <module name="UnusedImports"/>
        <module name="FinalLocalVariable"/>
        <module name="EmptyBlock"/>
    </module>
</module>
