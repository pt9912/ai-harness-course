<?xml version="1.0" encoding="utf-8"?>
<!--
  Coverlet-Konfiguration für `make coverage-gate`. LH-QA-Coverage 70 %
  (bootstrap-aware). Schwelle gilt für Line-Coverage gesamt.
-->
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <Format>cobertura</Format>
          <Exclude>[xunit.*]*,[*.Tests]*</Exclude>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
