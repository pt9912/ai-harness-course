{
  "set_name": "welle-1-baseline",
  "description": "Baseline-Replays für DocSearch nach Welle-1-Abschluss. Drei Replays decken Happy Path, Boundary und Negative je LH-FA-02 ab.",
  "created": "2026-05-28",
  "model_version": "local-embed-v3@2026-05-15",
  "tie_break_strategy": "sort_stable_then_doc_path_then_section_index",
  "max_topk": 100,
  "embedding_dim": 1024,
  "cases": [
    {
      "id": "case-001-happy-path",
      "kind": "happy",
      "input": {
        "endpoint": "/search",
        "body": {"q": "Wie initialisiere ich den Index?", "k": 5}
      },
      "expected": {
        "status": 200,
        "result_count": 5,
        "top_doc_path": "docs/init.md",
        "top_section_title_contains": "Initialisierung",
        "top_score_min": 0.7
      },
      "bezug": "LH-FA-02"
    },
    {
      "id": "case-002-boundary-k-clamped",
      "kind": "boundary",
      "input": {
        "endpoint": "/search",
        "body": {"q": "Frage X", "k": 500}
      },
      "expected": {
        "status": 200,
        "result_count_max": 100,
        "response_header": {"X-Topk-Clamped": "100"}
      },
      "bezug": "LH-FA-02 Boundary"
    },
    {
      "id": "case-003-negative-empty-query",
      "kind": "negative",
      "input": {
        "endpoint": "/search",
        "body": {"q": "", "k": 5}
      },
      "expected": {
        "status": 400,
        "error_code": "E002",
        "log_event": "search_invalid"
      },
      "bezug": "LH-FA-02 Negative"
    }
  ],
  "notes": "Bei Modell-Wechsel: top_score_min und top_doc_path-Erwartung neu kalibrieren, top_section_title_contains bleibt semantischer Anker. Determinismus-Check: zwei Läufe derselben Eingabe müssen byte-identische `cases[*].actual.results`-Listen erzeugen — Reihenfolge auch bei gleichen Scores."
}
